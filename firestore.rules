rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: companies
    // Fields: name, ownerId, createdAt
    //
    // Collection: users
    // Fields: uid, email, companyId, role, createdAt
    //
    // Collection: clients
    // Fields: companyId, firstName, lastName, dni, cuil, email, businessName, address, city, province, country, installments, totalAmountUSD, comments, createdAt
    //
    // Collection: payments
    // Fields: companyId, clientId, installmentNumber, amount, currency, amountUSD, exchangeRate, paymentDate, dueDate, paymentMethod, status, createdAt
    //
    // Collection: cashflow
    // Fields: companyId, type, amountUSD, category, date, description, paymentId, createdAt
    //
    // Collection: staff
    // Fields: companyId, name, role, email, baseSalaryUSD, createdAt
    //
    // Collection: payroll
    // Fields: companyId, staffId, staffName, amountUSD, date, period, paymentMethod, createdAt
    //
    // Collection: commissions
    // Fields: companyId, staffId, staffName, clientId, clientName, paymentId, amountUSD, percentage, staffRole, status, date, createdAt
    //
    // Collection: settings
    // Fields: companyId, currency, decimals, theme, paymentMethods, updatedAt, payrollDay, defaultSetterCommissionPct, defaultCloserCommissionPct
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getCompanyId() {
      return getUserData().companyId;
    }

    function getRole() {
      return getUserData().role;
    }

    function isCompanyMember(companyId) {
      return isAuthenticated() && getCompanyId() == companyId;
    }

    function isAdmin() {
      return isAuthenticated() && getRole() == 'admin';
    }

    function isEditor() {
      return isAuthenticated() && (getRole() == 'admin' || getRole() == 'editor');
    }

    function isAuthorized(companyId) {
      return isCompanyMember(companyId);
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    // Domain Validators
    function isValidCompany(data) {
      return hasRequiredFields(['name', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() > 0 &&
             data.ownerId == request.auth.uid;
    }

    function isValidUserProfile(data) {
      return hasRequiredFields(['uid', 'email', 'companyId', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'editor', 'viewer'];
    }

    function isValidClient(data) {
      return hasRequiredFields(['companyId', 'firstName', 'lastName', 'totalAmountUSD', 'installments', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.firstName is string && data.firstName.size() > 0 &&
             data.lastName is string && data.lastName.size() > 0 &&
             data.totalAmountUSD is number && data.totalAmountUSD >= 0 &&
             data.installments is number && data.installments >= 1;
    }

    function isValidPayment(data) {
      return hasRequiredFields(['companyId', 'clientId', 'installmentNumber', 'amountUSD', 'status', 'dueDate', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.clientId is string &&
             data.installmentNumber is number &&
             data.amountUSD is number && data.amountUSD >= 0 &&
             data.status in ['paid', 'pending'];
    }

    function isValidCashflow(data) {
      return hasRequiredFields(['companyId', 'type', 'amountUSD', 'category', 'date', 'description', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.type in ['income', 'expense'] &&
             data.amountUSD is number && data.amountUSD >= 0 &&
             data.category is string &&
             data.date is string &&
             data.description is string && data.description.size() <= 500;
    }

    function isValidStaff(data) {
      return hasRequiredFields(['companyId', 'name', 'role', 'type', 'baseSalaryUSD', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.name is string && data.name.size() > 0 &&
             data.role is string &&
             data.type in ['setter', 'closer', 'other'] &&
             data.baseSalaryUSD is number && data.baseSalaryUSD >= 0;
    }

    function isValidPayroll(data) {
      return hasRequiredFields(['companyId', 'staffId', 'staffName', 'amountUSD', 'date', 'period', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.staffId is string &&
             data.amountUSD is number && data.amountUSD >= 0;
    }

    function isValidCommission(data) {
      return hasRequiredFields(['companyId', 'staffId', 'clientId', 'amountUSD', 'status', 'createdAt']) &&
             data.companyId == getCompanyId() &&
             data.status in ['paid', 'pending'] &&
             data.amountUSD is number && data.amountUSD >= 0;
    }

    function isValidSettings(data) {
      return hasRequiredFields(['companyId', 'currency', 'decimals', 'paymentMethods']) &&
             data.companyId == getCompanyId() &&
             data.currency in ['USD', 'ARS', 'EUR'] &&
             data.decimals is number && data.decimals >= 0 && data.decimals <= 2 &&
             data.paymentMethods is list;
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated() && (resource.data.ownerId == request.auth.uid || isCompanyMember(companyId));
      allow create: if isAuthenticated() && isValidCompany(request.resource.data);
      allow update: if isAuthenticated() && resource.data.ownerId == request.auth.uid && isValidCompany(request.resource.data);
      allow delete: if false;
    }

    match /users/{uid} {
      allow read: if isAuthenticated() && (request.auth.uid == uid || getCompanyId() == resource.data.companyId);
      allow create: if isAuthenticated() && request.auth.uid == uid && isValidUserProfile(request.resource.data);
      allow update: if isAuthenticated() && (request.auth.uid == uid || isAdmin()) && isValidUserProfile(request.resource.data);
      allow delete: if isAuthenticated() && isAdmin() && request.auth.uid != uid;
    }

    match /clients/{clientId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidClient(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidClient(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /payments/{paymentId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidPayment(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidPayment(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId', 'clientId', 'installmentNumber']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /cashflow/{entryId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidCashflow(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidCashflow(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId', 'type', 'amountUSD', 'date']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /staff/{staffId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidStaff(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidStaff(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /payroll/{payrollId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidPayroll(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidPayroll(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId', 'staffId', 'amountUSD']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /commissions/{commissionId} {
      allow read: if isAuthorized(resource.data.companyId);
      allow create: if isAuthorized(request.resource.data.companyId) && isEditor() && isValidCommission(request.resource.data);
      allow update: if isAuthorized(resource.data.companyId) && isEditor() && isValidCommission(request.resource.data) && areImmutableFieldsUnchanged(['createdAt', 'companyId', 'staffId', 'clientId', 'amountUSD']);
      allow delete: if isAuthorized(resource.data.companyId) && isAdmin();
    }

    match /settings/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isCompanyMember(resource.data.companyId));
      allow create, update: if isAuthenticated() && isAuthorized(request.resource.data.companyId) && isEditor() && isValidSettings(request.resource.data);
      allow delete: if isAuthenticated() && isAuthorized(resource.data.companyId) && isAdmin();
    }
  }
}
